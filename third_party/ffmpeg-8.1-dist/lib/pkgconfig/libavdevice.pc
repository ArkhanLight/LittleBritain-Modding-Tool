prefix=/e/ffmpeg-build/ffmpeg-8.1-dist
exec_prefix=${prefix}
libdir=/e/ffmpeg-build/ffmpeg-8.1-dist/lib
includedir=/e/ffmpeg-build/ffmpeg-8.1-dist/include

Name: libavdevice
Description: FFmpeg device handling library
Version: 62.3.100
Requires: libavfilter >= 11.14.100, libswscale >= 9.5.100, libavformat >= 62.12.100, libavcodec >= 62.28.100, libswresample >= 6.3.100, libavutil >= 60.26.100
Requires.private: 
Conflicts:
Libs: -L${libdir}  -lavdevice psapi.lib ole32.lib strmiids.lib uuid.lib oleaut32.lib shlwapi.lib gdi32.lib vfw32.lib
Libs.private: 
Cflags: -I${includedir}
